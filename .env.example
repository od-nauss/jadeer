# =============================================================
# منصة جدير - متغيرات البيئة
# Jadeer Platform - Environment Variables
# =============================================================
# انسخ هذا الملف إلى .env.local وأضف القيم الفعلية
# Copy this file to .env.local and fill in actual values
# لا ترفع .env.local إلى GitHub أبدًا
# Never commit .env.local to GitHub
# =============================================================

# -------------------------------------------------------------
# Supabase Configuration (مطلوب)
# الحصول عليها من: https://app.supabase.com/project/_/settings/api
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# هذا المفتاح يستخدم في الخادم فقط - لا تكشفه أبدًا للعميل
# This key is server-side only - never expose it to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -------------------------------------------------------------
# AI Provider Configuration (مطلوب لطبقة الذكاء الاصطناعي)
# AI_PROVIDER: openai | anthropic | custom
# -------------------------------------------------------------
AI_PROVIDER=anthropic
AI_API_KEY=your-ai-api-key
AI_MODEL=claude-sonnet-4-5-20250929
AI_BASE_URL=https://api.anthropic.com/v1

# -------------------------------------------------------------
# Application Configuration
# -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# كلمة مرور مركز العرض التنفيذي (افتراضية - يمكن تغييرها لاحقًا من الإعدادات)
# Executive Center default password (can be changed later from Admin settings)
EXECUTIVE_CENTER_DEFAULT_CODE=1170
